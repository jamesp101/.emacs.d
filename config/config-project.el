;;;; config-project.el -*- lexical-binding: t; -*-(straight-use-package 'magit)(straight-use-package 'git-gutter)(straight-use-package 'treemacs)(straight-use-package 'treemacs-icons-dired)(customize-set-variable 'project-list-file (expand-file-name ".projects" user-emacs-directory))(defcustom project-cmds-prefix-key "p" "Project Options")(define-prefix-command 'project-cmds-prefix-key)(define-key 'project-cmds-prefix-key (kbd "p") 'project-switch-project)(define-key 'project-cmds-prefix-key (kbd "g") 'magit-status)(define-key 'project-cmds-prefix-key (kbd "d") 'projectile-dired)(define-key 'project-cmds-prefix-key (kbd "f") 'consult-ripgrep)(define-key 'project-cmds-prefix-key (kbd "k") 'project-kill-buffers)(global-set-key (kbd "C-x b") 'consult-project-buffer)(with-eval-after-load 'meow  (meow-leader-define-key   '("p" . project-cmds-prefix-key)   '("SPC" . project-find-file)));; Magit(require 'magit);;GitGutter(require 'git-gutter)(global-git-gutter-mode)          ;; Treemacs(require 'treemacs)(require 'treemacs-projectile)(setq treemacs-position 'right)(add-hook 'treemacs-mode-hook #'(lambda ()                                  (turn-on-solaire-mode)                                  (hide-mode-line-mode)))          ;; All The Icons(with-eval-after-load 'all-the-icons    (straight-use-package 'treemacs-all-the-icons)  (straight-use-package 'treemacs-icons-dired)  (require 'treemacs-all-the-icons)  (require 'treemacs-icons-dired)  (treemacs-load-theme "all-the-icons")  (treemacs-icons-dired-mode))(with-eval-after-load 'meow  (meow-leader-define-key   '("t" . treemacs)   '("g" . magit)))(provide 'config-project)