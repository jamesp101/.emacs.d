;;;; config-project.el -*- lexical-binding: t; -*-(straight-use-package 'projectile)(straight-use-package 'consult-projectile)(straight-use-package 'magit)(straight-use-package 'git-gutter)(straight-use-package 'treemacs)(straight-use-package 'treemacs-projectile)(straight-use-package 'treemacs-icons-dired);; Projectile (require 'projectile)(require 'consult-projectile)(setq projecitle-mode-line-function      '(lambda ()         (format "[%s]" projectile-project-name)))(setq projectile-indexing-method 'alien      projectile-project-serach-path      '(default-directory "~/projects"))(defcustom project-cmds-prefix-key "p" "Project Options")(define-prefix-command 'project-cmds-prefix-key)(define-key 'project-cmds-prefix-key (kbd "p") 'consult-projectile-switch-project)(define-key 'project-cmds-prefix-key (kbd "f") 'consult-ripgrep)(define-key 'project-cmds-prefix-key (kbd "g") 'magit-status)(define-key 'project-cmds-prefix-key (kbd "d") 'projectile-dired)(define-key 'project-cmds-prefix-key (kbd "k") 'projectile-kill-buffers)(define-key 'project-cmds-prefix-key (kbd "r") 'projectile-invalidate-cache)(with-eval-after-load 'meow  (meow-leader-define-key   '("p" . project-cmds-prefix-key)   '("SPC" . consult-projectile)))(add-hook 'after-init-hook 'projectile-mode 1) ;; Magit(require 'magit);;GitGutter(require 'git-gutter)(global-git-gutter-mode)          ;; Treemacs(require 'treemacs)(require 'treemacs-projectile)(setq treemacs-position 'right)(add-hook 'treemacs-mode-hook          #'(lambda ()              (turn-on-solaire-mode)              (hide-mode-line-mode)))          ;; All The Icons  (straight-use-package 'treemacs-all-the-icons)(straight-use-package 'treemacs-icons-dired)(require 'treemacs-all-the-icons)(require 'treemacs-icons-dired)(treemacs-load-theme "all-the-icons")(treemacs-icons-dired-mode)(with-eval-after-load 'meow  (meow-leader-define-key   '("t" . treemacs-select-window)   '("g" . magit)))(provide 'config-project)